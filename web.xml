<!DOCTYPE html>
<html lang="ar" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Zaid Hamed | Root</title>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;600&family=Tajawal:wght@500;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --bg-dark: #0d1117;
            --code-green: #2ecc71;
            --code-blue: #58a6ff;
            --code-gray: #8b949e;
            --border: #30363d;
            --text: #c9d1d9;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text);
            font-family: 'Fira Code', 'Tajawal', monospace;
            display: flex;
            justify-content: center;
            padding: 20px;
            line-height: 1.6;
        }

        .terminal-window {
            width: 100%;
            max-width: 500px;
            background: #161b22;
            border: 1px solid var(--border);
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        }

        /* شريط التحكم العلوي النافذة */
        .terminal-header {
            background: #21262d;
            padding: 10px 15px;
            display: flex;
            gap: 8px;
            border-bottom: 1px solid var(--border);
        }

        .dot { width: 12px; height: 12px; border-radius: 50%; }
        .red { background: #ff5f56; }
        .yellow { background: #ffbd2e; }
        .green { background: #27c93f; }

        .content { padding: 30px 20px; }

        /* الهوية الشخصية */
        .user-intro {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 40px;
        }

        .avatar {
            width: 80px;
            height: 80px;
            border: 2px solid var(--code-blue);
            padding: 2px;
            border-radius: 4px;
            object-fit: cover;
        }

        .command {
            color: var(--code-green);
            font-weight: bold;
        }

        .command::before { content: "$ "; color: var(--code-gray); }

        .name-txt {
            font-size: 1.5rem;
            font-family: 'Tajawal', sans-serif;
            font-weight: 800;
        }

        /* قائمة الروابط */
        .links-grid {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .link-item {
            display: block;
            padding: 12px 15px;
            border: 1px solid var(--border);
            border-radius: 4px;
            text-decoration: none;
            color: var(--code-blue);
            transition: 0.2s;
            font-size: 0.95rem;
        }

        .link-item:hover {
            background: rgba(88, 166, 255, 0.1);
            border-color: var(--code-blue);
            padding-right: 25px;
        }

        .link-item::after {
            content: " ->";
            opacity: 0;
            transition: 0.2s;
        }

        .link-item:hover::after { opacity: 1; }

        /* قسم الاهتمامات (بأسلوب الكود) */
        .footer-interests {
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px dashed var(--border);
        }

        .json-key { color: #ff7b72; }
        .json-val { color: #a5d6ff; }

        .cursor {
            display: inline-block;
            width: 8px;
            height: 18px;
            background: var(--code-green);
            animation: blink 1s infinite;
            vertical-align: middle;
            margin-right: 5px;
        }

        @keyframes blink {
            0%, 100% { opacity: 1; }
            50% { opacity: 0; }
        }

        .poetry {
            margin-top: 30px;
            color: var(--code-gray);
            font-size: 0.85rem;
            text-align: center;
            font-style: italic;
        }
    </style>
</head>
<body>

    <div class="terminal-window">
        <div class="terminal-header">
            <div class="dot red"></div>
            <div class="dot yellow"></div>
            <div class="dot green"></div>
        </div>

        <div class="content">
            <div class="user-intro">
                <img src="https://raw.githubusercontent.com/Zie0d/mylove/refs/heads/main/IMG_3495.jpg" class="avatar" alt="Zaid">
                <div>
                    <div class="command">whoami</div>
                    <div class="name-txt">زيد حامد</div>
                </div>
            </div>

            <div class="command">fetch --links</div>
            <div class="links-grid">
                <a href="https://t.me/zie0d1" class="link-item">Telegram / @zie0d1</a>
                <a href="https://instagram.com/zie0d1" class="link-item">Instagram / @zie0d1</a>
                <a href="https://wa.me/9647736308670" class="link-item">WhatsApp / Contact</a>
                <a href="mailto:zy0aid@gmail.com" class="link-item">Mail / Primary</a>
            </div>

            <div class="footer-interests">
                <div class="command">cat interests.json</div>
                <div style="font-size: 0.85rem; margin-top: 10px;">
                    {<br>
                    &nbsp;&nbsp;<span class="json-key">"logic"</span>: <span class="json-val">"برمجة وتطوير تطبيقات"</span>,<br>
                    &nbsp;&nbsp;<span class="json-key">"strategy"</span>: <span class="json-val">"الشطرنج"</span>,<br>
                    &nbsp;&nbsp;<span class="json-key">"creative"</span>: <span class="json-val">"الأدب والشعر"</span>,<br>
                    &nbsp;&nbsp;<span class="json-key">"academic"</span>: <span class="json-val">"الطب البيطري"</span><br>
                    }
                </div>
            </div>

            <div class="poetry">
                // "إِذا غامَرتَ في شَرَفٍ مَرومٍ.. فَلا تَقنَع بِما دونَ النُجومِ"
            </div>

            <div style="margin-top: 20px;">
                <span class="command"></span><span class="cursor"></span>
            </div>
        </div>
    </div>

</body>
</html>
